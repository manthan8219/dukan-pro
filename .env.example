# Nest API — production: your deployed API origin (no trailing slash), e.g. https://api.example.com
VITE_API_URL=http://localhost:3000

# --- Vercel: add the same keys in Project → Settings → Environment Variables (all environments you deploy).
# Vite only exposes variables prefixed with VITE_. Redeploy after changing env vars.

# Google Maps — required for draggable shop / delivery map (Maps JavaScript API)
# Cloud Console → APIs & Services → enable “Maps JavaScript API” → copy browser key.
VITE_GOOGLE_MAPS_API_KEY=

# Firebase (required for login / sign-up)
# Create a Web app in Firebase Console → Project settings → Your apps.
# Authentication → Sign-in method → enable Google. Add localhost to Authorized domains.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional / recommended (same Firebase config object)
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_MEASUREMENT_ID=   # enables Google Analytics in the web app
